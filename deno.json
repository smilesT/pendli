{
  "version": "0.4.2",
  "tasks": {
    "dev": "deno run -A npm:vite",
    "build": "deno run -A npm:vite build",
    "preview": "deno run -A npm:vite preview",
    "test": "deno test test/"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "strict": true
  },
  "imports": {
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.2.2",
    "@types/papaparse": "npm:@types/papaparse@^5.5.2",
    "@types/uuid": "npm:@types/uuid@^11.0.0",
    "@vitejs/plugin-react": "npm:@vitejs/plugin-react@^6.0.1",
    "ical.js": "npm:ical.js@^2.2.1",
    "papaparse": "npm:papaparse@^5.5.3",
    "react": "npm:react@^19",
    "react-dom": "npm:react-dom@^19",
    "tailwindcss": "npm:tailwindcss@^4.2.2",
    "uuid": "npm:uuid@^13.0.0",
    "vite-plugin-pwa": "npm:vite-plugin-pwa@^1.2.0",
    "workbox-precaching": "npm:workbox-precaching@^7.4.0",
    "zustand": "npm:zustand@^5.0.12"
  },
  "nodeModulesDir": "auto",
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "include": [
        "no-unused-vars",
        "no-explicit-any",
        "no-inferrable-types",
        "eqeqeq",
        "no-eval",
        "no-throw-literal",
        "no-self-compare",
        "no-sparse-arrays",
        "no-const-assign",
        "no-dupe-args",
        "no-dupe-keys",
        "no-unreachable",
        "no-unsafe-negation",
        "no-shadow-restricted-names",
        "no-delete-var",
        "no-empty-pattern",
        "no-ex-assign",
        "no-func-assign",
        "no-inner-declarations",
        "ban-unused-ignore",
        "no-non-null-assertion"
      ]
    },
    "exclude": ["node_modules/", "dist/", ".vite/", "test/"]
  }
}
